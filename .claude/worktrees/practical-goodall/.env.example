# ===========================================
# Meeting Toolkit - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ----- Application -----
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key

# ----- Database -----
DATABASE_URL=postgresql+asyncpg://toolkit:toolkit_dev@localhost:5432/meeting_toolkit
DATABASE_POOL_SIZE=10

# ----- Redis -----
REDIS_URL=redis://localhost:6379/0

# ----- LLM Configuration -----
# Tier 1: Cloud API (default)
LLM_DEFAULT_TIER=1
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Tier 2: Redaction Layer
# Redaction patterns are configured in backend/app/services/llm/redaction.py

# Tier 3: Self-hosted (Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# LLM Model Selection
LLM_PRIMARY_MODEL=claude-sonnet-4-20250514
LLM_BUDGET_MODEL=gpt-4o-mini
LLM_SELFHOSTED_MODEL=llama3.3:70b

# ----- Google OAuth (Calendar + Drive) -----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ----- Authentication (Auth0) -----
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_AUDIENCE=https://api.meeting-toolkit.com

# ----- Email (SendGrid) -----
SENDGRID_API_KEY=your-sendgrid-key
EMAIL_FROM=noreply@meeting-toolkit.com

# ----- Frontend -----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Sentry (Error Tracking) -----
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
