# ===========================================
# Meeting Toolkit - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
#
# QUICK START:
#   1. Copy this file:  cp .env.example .env
#   2. Start the app:   docker compose up -d
#   3. Visit:           http://localhost:3000/setup
#   4. The Getting Started page will guide you through
#      configuring your API keys — no manual .env editing needed!
#
# Alternatively, you can fill in the values below before starting.

# ----- Application -----
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me

# ----- Setup Token -----
# Used to secure the Getting Started / Settings page.
# Leave blank for first-time setup — a token will be auto-generated
# when you save your settings through the UI. Store it safely!
SETUP_TOKEN=

# ----- Database -----
# NOTE: When running in Docker, the hostname is overridden to 'db'
# automatically via docker-compose.yml. The 'localhost' value here
# is for local development outside Docker.
DATABASE_URL=postgresql+asyncpg://toolkit:toolkit_dev@localhost:5432/meeting_toolkit
DATABASE_POOL_SIZE=10

# ----- Redis -----
# NOTE: When running in Docker, the hostname is overridden to 'redis'
# automatically via docker-compose.yml.
REDIS_URL=redis://localhost:6379/0

# ----- LLM Configuration -----
# At least one LLM provider (Anthropic or OpenAI) is required for
# AI-powered analysis. Without any API keys, the toolkit uses a
# built-in MockProvider with heuristic analysis.
#
# You can configure these through the Getting Started page at
# http://localhost:3000/setup instead of editing this file.

# Tier 1: Cloud API (default)
LLM_DEFAULT_TIER=1
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Tier 2: Redaction Layer
# Redaction patterns are configured in backend/app/services/llm/redaction.py

# Tier 3: Self-hosted (Ollama)
# Only needed if running Ollama locally for air-gapped processing
OLLAMA_BASE_URL=http://localhost:11434

# LLM Model Selection
LLM_PRIMARY_MODEL=claude-sonnet-4-20250514
LLM_BUDGET_MODEL=gpt-4o-mini
LLM_SELFHOSTED_MODEL=llama3.3:70b

# ----- Google OAuth (Calendar + Drive) -----
# Optional — enables calendar integration and document gathering.
# Get credentials from: https://console.cloud.google.com
#   -> APIs & Services -> Credentials -> Create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ----- Authentication (Auth0) -----
# Optional — for user authentication in production.
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_AUDIENCE=https://api.meeting-toolkit.com

# ----- Email (SendGrid) -----
# Optional — for sending meeting minutes and follow-up reminders.
SENDGRID_API_KEY=your-sendgrid-key
EMAIL_FROM=noreply@meeting-toolkit.com

# ----- Frontend -----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Sentry (Error Tracking) -----
# Optional — for production error monitoring.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
